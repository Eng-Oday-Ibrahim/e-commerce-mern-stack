{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/shared/*" : [
        "./src/shared/*"
      ],
      "@/config/*" : [
        "./src/config/*"
      ],
      "@/infrastructure/*" : [
        "./src/infrastructure/*"
      ],
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
